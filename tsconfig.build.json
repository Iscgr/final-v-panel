{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "node16",
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": false,
    "allowJs": false,
    "rootDir": ".",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": [
    "server/tests",
    "**/*.test.ts",
    "dist",
    "node_modules"
  ]
}
